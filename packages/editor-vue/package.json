{
  "name": "@kungal/editor-vue",
  "version": "0.20.0",
  "description": "KunEditor Vue 3 layer — the headless <KunEditor> component (dual WYSIWYG / markdown-source), toolbar and plugin views. Ships zero CSS and no UI-kit dependency; consumes @kungal/editor-core, and pairs with @kungal/editor-nuxt for optional KunUI chrome.",
  "type": "module",
  "keywords": [
    "kungal",
    "kun-editor",
    "milkdown",
    "vue",
    "vue3",
    "markdown",
    "editor",
    "wysiwyg"
  ],
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kungal/kun-editor.git",
    "directory": "packages/editor-vue"
  },
  "homepage": "https://github.com/kungal/kun-editor#readme",
  "bugs": "https://github.com/kungal/kun-editor/issues",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "files": [
    "CHANGELOG.md",
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "vite build && vue-tsc -p tsconfig.build.json",
    "dev": "vite build --watch",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@kungal/editor-core": "workspace:*",
    "@prosemirror-adapter/vue": "^0.4.6"
  },
  "peerDependencies": {
    "@codemirror/lang-markdown": "^6.0.0",
    "@codemirror/state": "^6.0.0",
    "@codemirror/view": "^6.0.0",
    "@milkdown/kit": "^7.21.2",
    "@milkdown/prose": "^7.21.2",
    "@milkdown/vue": "^7.21.2",
    "codemirror": "^6.0.0",
    "vue": "^3.5.0"
  },
  "peerDependenciesMeta": {
    "@codemirror/lang-markdown": {
      "optional": true
    },
    "@codemirror/state": {
      "optional": true
    },
    "@codemirror/view": {
      "optional": true
    },
    "codemirror": {
      "optional": true
    }
  },
  "devDependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.39.4",
    "@kungal/editor-core": "workspace:*",
    "@milkdown/kit": "^7.21.2",
    "@milkdown/prose": "^7.21.2",
    "@milkdown/vue": "7.21.2",
    "@types/node": "^22.10.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "codemirror": "^6.0.2",
    "typescript": "^5.7.0",
    "vite": "^8.0.16",
    "vue": "^3.5.35",
    "vue-tsc": "^3.3.3"
  }
}
