{
  "name": "@kungal/editor-vue",
  "version": "0.3.0",
  "description": "KunEditor Vue 3 layer — the <KunEditor> component (dual WYSIWYG / markdown-source), toolbar and plugin views. Consumes @kungal/editor-core; pairs with @kungal/ui-vue.",
  "type": "module",
  "keywords": [
    "kungal",
    "kun-editor",
    "milkdown",
    "vue",
    "vue3",
    "markdown",
    "editor",
    "wysiwyg"
  ],
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kungal/kun-editor.git",
    "directory": "packages/editor-vue"
  },
  "homepage": "https://github.com/kungal/kun-editor#readme",
  "bugs": "https://github.com/kungal/kun-editor/issues",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "*.css",
    "*.vue"
  ],
  "files": [
    "CHANGELOG.md",
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style.css": "./dist/style.css"
  },
  "scripts": {
    "build": "vite build && vue-tsc -p tsconfig.build.json",
    "dev": "vite build --watch",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@kungal/editor-core": "workspace:*",
    "@prosemirror-adapter/vue": "^0.4.6"
  },
  "peerDependencies": {
    "@kungal/ui-vue": "^2.7.0",
    "@milkdown/kit": "^7.21.2",
    "@milkdown/prose": "^7.21.2",
    "@milkdown/vue": "^7.21.2",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@kungal/editor-core": "workspace:*",
    "@milkdown/kit": "^7.21.2",
    "@milkdown/prose": "^7.21.2",
    "@milkdown/vue": "7.21.2",
    "@types/node": "^22.10.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "typescript": "^5.7.0",
    "vite": "^8.0.16",
    "vue": "^3.5.35",
    "vue-tsc": "^3.3.3"
  }
}
