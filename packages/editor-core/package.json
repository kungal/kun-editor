{
  "name": "@kungal/editor-core",
  "version": "0.20.0",
  "description": "KunEditor framework-agnostic core — the Milkdown plugin bundle (spoiler / mention / quote / katex / upload / code-block) plus the adapter contracts. No Vue/React.",
  "type": "module",
  "keywords": [
    "kungal",
    "kun-editor",
    "milkdown",
    "prosemirror",
    "markdown",
    "editor",
    "wysiwyg"
  ],
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kungal/kun-editor.git",
    "directory": "packages/editor-core"
  },
  "homepage": "https://github.com/kungal/kun-editor#readme",
  "bugs": "https://github.com/kungal/kun-editor/issues",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "files": [
    "CHANGELOG.md",
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./preset": {
      "types": "./dist/preset/index.d.ts",
      "import": "./dist/preset/index.js",
      "require": "./dist/preset/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "remark-math": "^6.0.0",
    "unist-util-visit": "^5.0.0"
  },
  "peerDependencies": {
    "@codemirror/commands": "^6.0.0",
    "@codemirror/language": "^6.0.0",
    "@codemirror/language-data": "^6.0.0",
    "@codemirror/state": "^6.0.0",
    "@codemirror/view": "^6.0.0",
    "@lezer/highlight": "^1.0.0",
    "@milkdown/kit": "^7.21.2",
    "@milkdown/prose": "^7.21.2",
    "codemirror": "^6.0.0",
    "katex": "^0.16.0"
  },
  "peerDependenciesMeta": {
    "@codemirror/commands": {
      "optional": true
    },
    "@codemirror/language": {
      "optional": true
    },
    "@codemirror/language-data": {
      "optional": true
    },
    "@codemirror/state": {
      "optional": true
    },
    "@codemirror/view": {
      "optional": true
    },
    "@lezer/highlight": {
      "optional": true
    },
    "codemirror": {
      "optional": true
    },
    "katex": {
      "optional": true
    }
  },
  "devDependencies": {
    "@codemirror/commands": "^6.7.1",
    "@codemirror/language": "^6.11.3",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.39.4",
    "@lezer/highlight": "^1.2.1",
    "@milkdown/kit": "^7.21.2",
    "@milkdown/prose": "^7.21.2",
    "@types/katex": "^0.16.7",
    "@types/unist": "^3.0.3",
    "codemirror": "^6.0.2",
    "jsdom": "^25.0.1",
    "katex": "^0.16.27",
    "tsup": "^8.5.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
