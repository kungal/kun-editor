# Keep the dependency tree strict so packages can only import what they
# explicitly declare. This matters doubly for an editor: ProseMirror /
# Milkdown MUST resolve to a SINGLE copy at runtime (two prosemirror-model
# instances silently break schema identity). A strict tree makes an
# accidental second copy show up as a resolution error instead of a
# mysterious runtime bug — hence milkdown/prosemirror live as peerDependencies
# (see docs/architecture.md § singleton).
shamefully-hoist=false
